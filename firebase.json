{
	"firestore": {
		"rules": "firestore.rules",
		"indexes": "firestore.indexes.json"
	},
	"storage": {
		"rules": "storage.rules"
	},
	"functions": {
		"source": "functions",
		"runtime": "nodejs20"
	},
	"hosting": {
		"site": "pornosocial-c003d",
		"public": "build/web",
		"ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
		"rewrites": [
			{ "source": "/(?!.*\\.)", "destination": "/index.html" }
		],
		"headers": [
			{
				"source": "**",
				"headers": [
					{
						"key": "Content-Security-Policy",
						"value": "script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.firebaseapp.com https://*.gstatic.com https://*.googleapis.com; object-src 'none';"
					}
				]
			}
		]
	}
}