				"headers": [
					{
						"key": "Content-Security-Policy",
						"value": "script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.firebaseapp.com https://*.gstatic.com https://*.googleapis.com; object-src 'none';"
					}
				]
			}
		]
	}
